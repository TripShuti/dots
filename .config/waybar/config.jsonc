{
    "include": ["/home/trip/.config/waybar/modules.jsonc"],
    "layer": "top",
    "passthrough": false,
    "position": "center",
    "height": 38,
    "margin-top": 2,
    "margin-right": 0,
    "margin-left": 0,
    "spacing": 0,
    "exclusive": true,
    "tooltips": true,

    "modules-left": [
        "hyprland/workspaces",
        "custom/mediaplayer",
        "cava"
    ],
    
    "modules-center": [
        "custom/hyprsunset",
        "clock",
        "custom/app-launcher",
        "custom/genshin"
    ],

    "modules-right": [
        "hyprland/language",
        "tray",
        "custom/timer",
        "pulseaudio",
        "custom/pacman",
        "custom/power"
    ]
}